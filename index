    'understanding': 'knowing',
  };

  // ── Multi-word phrase suggestions (checked separately) ───────────────────
  const PHRASE_SIMPLER = {
    'orthopedic surgeon': 'bone doctor',
    'primary care physician': 'main doctor',
    'emergency room': 'ER',
    'emergency department': 'ER',
    'blood pressure': 'BP',
    'heart attack': 'heart attack',  // already plain
    'informed consent': 'your agreement to treatment',
    'adverse effects': 'side effects',
    'adverse event': 'bad reaction',
    'prior authorization': 'advance approval',
    'health care provider': 'doctor or nurse',
    'health insurance': 'insurance',
    'out of pocket': 'what you pay yourself',
    'physical therapy': 'PT (exercise treatment)',
    'occupational therapy': 'OT (daily skills training)',
    'intravenous therapy': 'IV treatment',
    'palliative care': 'comfort care',
    'intensive care': 'ICU (serious illness care)',
    'follow up': 'check-in visit',
    'diagnostic imaging': 'scan or X-ray',
    'over the counter': 'no prescription needed',
  };

  function buildSidebar(result) {
    const { fk, words, sylCounts, avgWPS, avgSPW } = result;
    const isHigh = fk > 7;

    if (!isHigh) {
      return `
        <div class="suggestion-section">
          <div class="suggestion-section-title">Score breakdown</div>
          <div class="score-breakdown">
            ${breakdownRows(avgWPS, avgSPW, fk)}
          </div>
        </div>
        <div class="suggestion-section">
          <div class="suggestion-section-title">Status</div>
          <div class="tip-item">
            <span class="tip-icon">✓</span>
            <span>Your text is at or below grade 7 — appropriate for a general audience. No changes needed.</span>
          </div>
        </div>
      `;
    }

    // Get complex words sorted by syllable count
    const complexMap = new Map();
    words.forEach((w, i) => {
      if (sylCounts[i] >= 3) {
        const key = w.toLowerCase();
        if (!complexMap.has(key) || complexMap.get(key) < sylCounts[i]) {
          complexMap.set(key, sylCounts[i]);
        }
      }
    });

    const sorted = [...complexMap.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12);

    const wordChips = sorted.map(([w, s]) => {
      const alt = SIMPLER[w];
      const altHtml = alt
        ? `<div style="font-size:0.7rem;color:var(--green);margin-top:3px;font-style:italic;">Try: "${alt}"</div>`
        : `<div style="font-size:0.68rem;color:var(--text-muted);margin-top:3px;">No suggestion — consider a simpler phrase</div>`;
      return `
        <div class="word-chip" style="flex-direction:column;align-items:flex-start;gap:0;">
          <div style="display:flex;justify-content:space-between;width:100%;align-items:center;">
            <span class="word-chip-text">${w}</span>
            <span class="word-chip-syl">${s} syl</span>
          </div>
          ${altHtml}
        </div>`;
    }).join('');

    // Phrase suggestions
    const lowerText = result.sentences.join(' ').toLowerCase();
    const matchedPhrases = Object.entries(PHRASE_SIMPLER).filter(([phrase]) => lowerText.includes(phrase));
    const phraseChips = matchedPhrases.map(([phrase, alt]) => `
      <div class="word-chip" style="flex-direction:column;align-items:flex-start;gap:0;">
        <div style="display:flex;justify-content:space-between;width:100%;align-items:center;">
          <span class="word-chip-text" style="font-style:italic;">"${phrase}"</span>
        </div>
        <div style="font-size:0.7rem;color:var(--green);margin-top:3px;font-style:italic;">Try: "${alt}"</div>
      </div>`).join('');

    const longSentences = result.sentences.filter(s => {
      const wc = (s.match(/\b[a-zA-Z']+\b/g) || []).length;
      return wc > 20;
    }).length;

    return `
      <div class="suggestion-section">
        <div class="suggestion-section-title">Score breakdown</div>
        <div class="score-breakdown">
          ${breakdownRows(avgWPS, avgSPW, fk)}
        </div>
      </div>

      <div class="suggestion-section">
        <div class="suggestion-section-title">Complex words (highlighted in text)</div>
        ${wordChips || '<div class="tip-item" style="color:var(--text-muted);font-size:0.8rem;">None found above 3 syllables.</div>'}
      </div>

      ${matchedPhrases.length > 0 ? `
      <div class="suggestion-section">
        <div class="suggestion-section-title">Medical phrases to simplify</div>
        ${phraseChips}
      </div>` : ''}

      <div class="suggestion-section">
        <div class="suggestion-section-title">Tips to lower grade level</div>
        <div class="tip-item"><span class="tip-icon">→</span><span>Replace multi-syllable words with shorter alternatives (yellow highlights).</span></div>
        ${longSentences > 0 ? `<div class="tip-item"><span class="tip-icon">→</span><span><strong style="color:var(--text)">${longSentences}</strong> sentence${longSentences > 1 ? 's are' : ' is'} over 20 words. Try breaking them up.</span></div>` : ''}
        <div class="tip-item"><span class="tip-icon">→</span><span>Aim for an average sentence length under 15–17 words.</span></div>
        <div class="tip-item"><span class="tip-icon">→</span><span>Use active voice — it shortens sentences naturally.</span></div>
        <div class="tip-item"><span class="tip-icon">→</span><span>Avoid nominalization (e.g., "consideration" → "consider").</span></div>
      </div>
    `;
  }

  function breakdownRows(avgWPS, avgSPW, fk) {
    const wpsContrib = (0.39 * avgWPS).toFixed(2);
    const spwContrib = (11.8 * avgSPW).toFixed(2);
    const wpsMax = Math.min(avgWPS / 35, 1);
    const spwMax = Math.min((avgSPW - 1) / 1.5, 1);

    return `
      <div class="breakdown-item">
        <div class="breakdown-label-row">
          <span class="breakdown-label">Avg words / sentence</span>
          <span class="breakdown-val">${avgWPS.toFixed(1)}</span>
        </div>
        <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${(wpsMax*100).toFixed(0)}%"></div></div>
      </div>
      <div class="breakdown-item">
        <div class="breakdown-label-row">
          <span class="breakdown-label">Avg syllables / word</span>
          <span class="breakdown-val">${avgSPW.toFixed(2)}</span>
        </div>
        <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${(Math.min(spwMax,1)*100).toFixed(0)}%"></div></div>
      </div>
    `;
  }

  // ── UI UPDATE ─────────────────────────────────────────────────────────────
  let currentTab = 'input';

  function update() {
    const text = document.getElementById('input-area').value;
    document.getElementById('char-count').textContent = text.length + ' chars';

    if (text.trim().length === 0) {
      resetUI();
      return;
    }

    const result = analyze(text);
    if (!result) { resetUI(); return; }

    const { fk, words, sylCounts, avgWPS, avgSPW } = result;
    const isHigh = fk > 7;
    const cls = isHigh ? 'red' : 'green';

    // Score strip
    const strip = document.getElementById('score-strip');
    strip.className = 'score-strip ' + cls;

    const sv = document.getElementById('score-value');
    sv.textContent = fk.toFixed(1);
    sv.className = 'score-value ' + cls;

    document.getElementById('stat-words').textContent = words.length;
    document.getElementById('stat-sents').textContent = result.sentences.length;
    document.getElementById('stat-syl').textContent = avgSPW.toFixed(2);
    document.getElementById('stat-wps').textContent = avgWPS.toFixed(1);

    const badge = document.getElementById('grade-badge');
    badge.textContent = gradeName(fk);
    badge.className = 'grade-badge ' + cls;

    // Output area
    document.getElementById('output-area').innerHTML = renderHighlighted(text, words, sylCounts);

    // Sidebar
    document.getElementById('sidebar-body').innerHTML = buildSidebar(result);
  }

  function resetUI() {
    const strip = document.getElementById('score-strip');
    strip.className = 'score-strip';

    const sv = document.getElementById('score-value');
    sv.textContent = '—';
    sv.className = 'score-value';

    ['stat-words','stat-sents','stat-syl','stat-wps'].forEach(id => {
      document.getElementById(id).textContent = id.includes('syl') || id.includes('wps') ? '0.00' : '0';
    });
    document.getElementById('stat-wps').textContent = '0.0';

    const badge = document.getElementById('grade-badge');
    badge.textContent = 'No text yet';
    badge.className = 'grade-badge';

    document.getElementById('output-area').innerHTML = '';
    document.getElementById('sidebar-body').innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">📊</div>
        <div class="empty-text">Start typing to see your readability score and suggestions.</div>
      </div>`;
  }

  function switchTab(tab) {
    currentTab = tab;
    const input = document.getElementById('input-area');
    const output = document.getElementById('output-area');
    const tabIn = document.getElementById('tab-input');
    const tabOut = document.getElementById('tab-output');

    if (tab === 'input') {
      input.style.display = '';
      output.style.display = 'none';
      tabIn.classList.add('active');
      tabOut.classList.remove('active');
    } else {
      input.style.display = 'none';
      output.style.display = 'block';
      tabIn.classList.remove('active');
      tabOut.classList.add('active');
      update(); // re-render highlights
    }
  }

  document.getElementById('input-area').addEventListener('input', () => {
    update();
  });

  // init
  resetUI();
</script>
