<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FK Readability Checker</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=JetBrains+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0c0c10;
      --surface: #15151c;
      --surface2: #1e1e28;
      --border: #2a2a38;
      --text: #eeeef2;
      --text-muted: #6e6e82;
      --green: #29d471;
      --green-dim: rgba(41, 212, 113, 0.1);
      --green-border: rgba(41, 212, 113, 0.35);
      --red: #ff4f4f;
      --red-dim: rgba(255, 79, 79, 0.1);
      --red-border: rgba(255, 79, 79, 0.35);
      --highlight-word: rgba(255, 190, 50, 0.28);
      --highlight-word-border: rgba(255, 190, 50, 0.6);
      --accent: #7b6bff;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* noise texture overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    header {
      padding: 28px 40px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: baseline;
      gap: 16px;
      position: relative;
      z-index: 1;
    }

    .logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.35rem;
      letter-spacing: -0.01em;
      color: var(--text);
    }

    .logo span {
      color: var(--accent);
    }

    .tagline {
      font-size: 0.78rem;
      color: var(--text-muted);
      font-family: 'JetBrains Mono', monospace;
      letter-spacing: 0.04em;
    }

    main {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 300px;
      grid-template-rows: auto 1fr;
      gap: 0;
      position: relative;
      z-index: 1;
    }

    /* ── SCORE STRIP ─────────────────────────────────── */
    .score-strip {
      grid-column: 1 / -1;
      padding: 20px 40px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 32px;
      background: var(--surface);
      transition: background 0.4s ease, border-color 0.4s ease;
    }

    .score-strip.green {
      background: var(--green-dim);
      border-bottom-color: var(--green-border);
    }

    .score-strip.red {
      background: var(--red-dim);
      border-bottom-color: var(--red-border);
    }

    .score-main {
      display: flex;
      align-items: baseline;
      gap: 10px;
    }

    .score-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .score-value {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 3rem;
      line-height: 1;
      transition: color 0.4s ease;
      color: var(--text-muted);
    }

    .score-value.green { color: var(--green); }
    .score-value.red   { color: var(--red); }

    .score-meta {
      display: flex;
      gap: 24px;
    }

    .stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .stat-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .stat-value {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text);
    }

    .grade-badge {
      margin-left: auto;
      padding: 6px 14px;
      border-radius: 4px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
      border: 1px solid var(--border);
      color: var(--text-muted);
      transition: all 0.4s ease;
    }

    .grade-badge.green {
      border-color: var(--green-border);
      color: var(--green);
      background: var(--green-dim);
    }

    .grade-badge.red {
      border-color: var(--red-border);
      color: var(--red);
      background: var(--red-dim);
    }

    /* ── EDITOR PANEL ────────────────────────────────── */
    .editor-panel {
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
    }

    .panel-header {
      padding: 16px 24px 12px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .panel-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .char-count {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--text-muted);
    }

    /* The actual editable area */
    #input-area {
      flex: 1;
      padding: 28px 32px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      line-height: 1.8;
      color: var(--text);
      background: transparent;
      border: none;
      outline: none;
      resize: none;
      min-height: 280px;
      caret-color: var(--accent);
    }

    #input-area::placeholder {
      color: var(--text-muted);
      font-style: italic;
    }

    /* Rendered output with highlights */
    #output-area {
      display: none;
      flex: 1;
      padding: 28px 32px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      line-height: 1.8;
      color: var(--text);
      overflow-y: auto;
      cursor: text;
    }

    #output-area .complex-word {
      background: var(--highlight-word);
      border-bottom: 2px solid var(--highlight-word-border);
      border-radius: 2px;
      cursor: help;
      position: relative;
    }

    #output-area .complex-word:hover::after {
      content: attr(data-syllables) ' syllables';
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: #2a2a38;
      color: var(--text);
      font-size: 0.7rem;
      padding: 4px 8px;
      border-radius: 4px;
      white-space: nowrap;
      font-family: 'JetBrains Mono', monospace;
      border: 1px solid var(--border);
      pointer-events: none;
      z-index: 10;
    }

    /* Tab bar */
    .tab-bar {
      display: flex;
      border-top: 1px solid var(--border);
      padding: 0 24px;
      gap: 0;
    }

    .tab-btn {
      padding: 10px 16px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      background: transparent;
      border: none;
      border-top: 2px solid transparent;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
    }

    .tab-btn.active {
      color: var(--text);
      border-top-color: var(--accent);
    }

    .tab-btn:hover:not(.active) {
      color: var(--text);
    }

    /* ── SUGGESTIONS SIDEBAR ─────────────────────────── */
    .sidebar {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .sidebar .panel-header {
      border-right: none;
    }

    .sidebar-body {
      flex: 1;
      overflow-y: auto;
      padding: 20px 20px 28px;
    }

    .sidebar-body::-webkit-scrollbar { width: 4px; }
    .sidebar-body::-webkit-scrollbar-track { background: transparent; }
    .sidebar-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      gap: 10px;
      text-align: center;
      padding: 40px 20px;
    }

    .empty-icon {
      font-size: 2rem;
      opacity: 0.3;
    }

    .empty-text {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .suggestion-section {
      margin-bottom: 24px;
    }

    .suggestion-section-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 10px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
    }

    .word-chip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 10px;
      border-radius: 6px;
      background: var(--surface2);
      border: 1px solid var(--border);
      margin-bottom: 6px;
      gap: 8px;
    }

    .word-chip-text {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      color: var(--text);
    }

    .word-chip-syl {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      color: var(--red);
      background: var(--red-dim);
      padding: 2px 6px;
      border-radius: 3px;
      flex-shrink: 0;
    }

    .tip-item {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 0.82rem;
      line-height: 1.5;
      color: var(--text-muted);
    }

    .tip-icon {
      flex-shrink: 0;
      font-size: 0.75rem;
      margin-top: 2px;
      color: var(--accent);
    }

    .progress-bar-wrap {
      height: 3px;
      background: var(--border);
      border-radius: 2px;
      margin-bottom: 6px;
      overflow: hidden;
    }

    .progress-bar-fill {
      height: 100%;
      border-radius: 2px;
      background: var(--red);
      transition: width 0.5s ease;
    }

    .score-breakdown {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .breakdown-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .breakdown-label-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.75rem;
    }

    .breakdown-label { color: var(--text-muted); }
    .breakdown-val { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--text); }

    /* ── SCROLLBAR ───────────────────────────────────── */
    #input-area::-webkit-scrollbar { width: 4px; }
    #input-area::-webkit-scrollbar-track { background: transparent; }
    #input-area::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    /* ── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 700px) {
      main { grid-template-columns: 1fr; grid-template-rows: auto 1fr auto; }
      .editor-panel { border-right: none; border-bottom: 1px solid var(--border); }
      .sidebar { max-height: 320px; }
      header { padding: 20px 20px 16px; }
      .score-strip { padding: 16px 20px; flex-wrap: wrap; }
    }

    /* Parenthetical content — excluded from FK, shown dimmed */
    #output-area .paren-excluded {
      opacity: 0.38;
      font-style: italic;
      cursor: default;
    }
    #output-area .paren-excluded:hover::after {
      content: 'Excluded from FK score';
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: #2a2a38;
      color: var(--text-muted);
      font-size: 0.7rem;
      padding: 4px 8px;
      border-radius: 4px;
      white-space: nowrap;
      font-family: 'JetBrains Mono', monospace;
      border: 1px solid var(--border);
      pointer-events: none;
      z-index: 10;
    }
    #output-area .paren-excluded { position: relative; }
  </style>
</head>
<body>

<header>
  <div class="logo">read<span>·</span>grade</div>
  <div class="tagline">flesch–kincaid grade level</div>
</header>

<main>
  <!-- Score Strip -->
  <div class="score-strip" id="score-strip">
    <div class="score-main">
      <div>
        <div class="score-label">Grade Level</div>
        <div class="score-value" id="score-value">—</div>
      </div>
    </div>
    <div class="score-meta">
      <div class="stat">
        <span class="stat-label">Words</span>
        <span class="stat-value" id="stat-words">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">Sentences</span>
        <span class="stat-value" id="stat-sents">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">Avg Syllables/Word</span>
        <span class="stat-value" id="stat-syl">0.00</span>
      </div>
      <div class="stat">
        <span class="stat-label">Avg Words/Sentence</span>
        <span class="stat-value" id="stat-wps">0.0</span>
      </div>
    </div>
    <div class="grade-badge" id="grade-badge">No text yet</div>
  </div>

  <!-- Editor Panel -->
  <div class="editor-panel">
    <div class="panel-header">
      <span class="panel-title">Input</span>
      <span class="char-count" id="char-count">0 chars</span>
    </div>

    <textarea id="input-area" spellcheck="true" placeholder="Paste or type your text here…"></textarea>
    <div id="output-area"></div>

    <div class="tab-bar">
      <button class="tab-btn active" id="tab-input" onclick="switchTab('input')">✏ Edit</button>
      <button class="tab-btn" id="tab-output" onclick="switchTab('output')">🔍 Highlight</button>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="sidebar">
    <div class="panel-header">
      <span class="panel-title">Suggestions</span>
    </div>
    <div class="sidebar-body" id="sidebar-body">
      <div class="empty-state">
        <div class="empty-icon">📊</div>
        <div class="empty-text">Start typing to see your readability score and suggestions.</div>
      </div>
    </div>
  </div>
</main>

<script>
  // ── SYLLABLE COUNTER ──────────────────────────────────────────────────────
  function countSyllables(word) {
    const w = word.toLowerCase().replace(/[^a-z]/g, '');
    if (!w) return 0;
    if (w.length <= 3) return 1;

    // Exception dictionary — covers known heuristic blind spots,
    // especially common medical/health vocabulary
    const exceptions = {
      // Directional compounds
      'everywhere': 3, 'somewhere': 2, 'anywhere': 2, 'nowhere': 2,
      // -ated words where stripping -ed loses syllables
      'created': 3, 'related': 3, 'located': 3, 'rotated': 3, 'donated': 3,
      'dedicated': 4, 'educated': 4, 'medicated': 4, 'indicated': 4,
      'replicated': 4, 'complicated': 4, 'associated': 5, 'appreciated': 5,
      // -es plurals/verbs where e is a full syllable
      'changes': 2, 'choices': 2, 'chances': 2, 'dances': 2, 'voices': 2,
      'places': 2, 'faces': 2, 'races': 2, 'pieces': 2, 'forces': 2,
      'reduces': 3, 'produces': 3, 'induces': 3,
      'requires': 3, 'desires': 3, 'expires': 3,
      // Medical conditions / terms
      'diabetes': 4, 'diagnosis': 4, 'prognosis': 3, 'psychosis': 3,
      'fibrosis': 3, 'cirrhosis': 3, 'sclerosis': 3,
      'medicine': 3, 'medicines': 3,
      // Adverbs that trip the heuristic
      'usually': 4, 'visually': 4, 'gradually': 4, 'manually': 4,
      'carefully': 3, 'widely': 2, 'likely': 2, 'timely': 2, 'lovely': 2,
      // Common words with silent/irregular syllables
      'people': 2, 'couple': 2, 'simple': 2, 'purple': 2,
      'table': 2, 'able': 2, 'cable': 2, 'stable': 2,
      'pressure': 2, 'treasure': 2, 'measure': 2, 'pleasure': 2,
      // Specialist titles
      'physician': 3, 'technician': 4, 'clinician': 4, 'dietitian': 4,
      // Multi-syllable adjectives
      'available': 4, 'comfortable': 4, 'vulnerable': 4,
      'coverage': 3, 'beverage': 3, 'average': 3,
    };

    if (exceptions[w]) return exceptions[w];

    let s = w;

    // Strip silent -ed only after non-vowel, non-t/d consonants
    s = s.replace(/([^tdaeiou])ed$/, '$1');

    // Strip silent final -e (not after vowels, not -le/-re patterns)
    s = s.replace(/([^aeioulr])e$/, '$1');

    // Strip consonant+es (e.g., "takes" → "tak") but preserve -ies
    s = s.replace(/([^aeiouy])es$/, '$1');

    // Strip leading y-as-consonant
    s = s.replace(/^y/, '');

    const matches = s.match(/[aeiouy]{1,2}/g);
    return Math.max(1, matches ? matches.length : 1);
  }

  // ── FK GRADE LEVEL ────────────────────────────────────────────────────────
  // Remove all content inside parentheses before FK analysis
  function stripParentheses(text) {
    return text.replace(/\([^)]*\)/g, '');
  }

  function tokenizeWords(text) {
    return text.match(/\b[a-zA-Z']+\b/g) || [];
  }

  function tokenizeSentences(text) {
    const raw = text.trim().split(/(?<=[.!?])\s+|(?<=[.!?])$/);
    return raw.filter(s => s.trim().length > 0);
  }

  function analyze(text) {
    const stripped = stripParentheses(text); // exclude parenthetical content from FK
    const words = tokenizeWords(stripped);
    const sentences = tokenizeSentences(stripped);

    if (words.length < 1 || sentences.length < 1) return null;

    const sylCounts = words.map(w => countSyllables(w));
    const totalSyl = sylCounts.reduce((a, b) => a + b, 0);

    const avgWPS = words.length / sentences.length;
    const avgSPW = totalSyl / words.length;
    const fk = 0.39 * avgWPS + 11.8 * avgSPW - 15.59;

    return {
      fk: Math.max(0, fk),
      words,
      sylCounts,
      sentences,
      totalSyl,
      avgWPS,
      avgSPW,
    };
  }

  // ── GRADE NAME ────────────────────────────────────────────────────────────
  function gradeName(fk) {
    if (fk < 1)  return '< Kindergarten';
    if (fk < 2)  return 'Grade 1';
    if (fk < 3)  return 'Grade 2';
    if (fk < 4)  return 'Grade 3';
    if (fk < 5)  return 'Grade 4';
    if (fk < 6)  return 'Grade 5';
    if (fk < 7)  return 'Grade 6';
    if (fk < 8)  return 'Grade 7';
    if (fk < 9)  return 'Grade 8';
    if (fk < 10) return 'Grade 9';
    if (fk < 11) return 'Grade 10';
    if (fk < 12) return 'Grade 11';
    if (fk < 13) return 'Grade 12';
    return 'College level';
  }

  // ── HIGHLIGHT RENDER ──────────────────────────────────────────────────────
  function renderHighlighted(text, words, sylCounts) {
    // Build set of complex word positions
    const complexSet = new Map(); // word (lowercase) -> syllable count
    words.forEach((w, i) => {
      if (sylCounts[i] >= 3) {
        const key = w.toLowerCase();
        if (!complexSet.has(key) || complexSet.get(key) < sylCounts[i]) {
          complexSet.set(key, sylCounts[i]);
        }
      }
    });

    // Tokenize raw text preserving whitespace
    const result = text.replace(/(\b[a-zA-Z']+\b)/g, (match) => {
      const lower = match.toLowerCase();
      if (complexSet.has(lower)) {
        const syl = complexSet.get(lower);
        return `<span class="complex-word" data-syllables="${syl}">${match}</span>`;
      }
      return match;
    });

    // Gray out parenthetical content (excluded from FK)
    let final = result.replace(/\(([^)]*)\)/g, (match, inner) => {
      // re-apply complex-word spans inside the paren if any, but wrap whole paren in muted style
      return `<span class="paren-excluded">(${inner})</span>`;
    });

    // Convert newlines to <br>
    return final.replace(/\n/g, '<br>');
  }

  // ── SUGGESTIONS BUILDER ───────────────────────────────────────────────────
  // Format: 'complex word': 'plain-language alternative'
  // Multi-word phrases handled via PHRASE_SIMPLER below
  const SIMPLER = {
    // ── Specialists & Providers ──────────────────────────────────────────
    'cardiologist': 'heart doctor',
    'dermatologist': 'skin doctor',
    'endocrinologist': 'hormone doctor',
    'gastroenterologist': 'stomach/gut doctor',
    'gynecologist': 'women\'s health doctor',
    'hematologist': 'blood doctor',
    'hepatologist': 'liver doctor',
    'immunologist': 'immune system doctor',
    'nephrologist': 'kidney doctor',
    'neurologist': 'brain and nerve doctor',
    'oncologist': 'cancer doctor',
    'ophthalmologist': 'eye doctor',
    'orthopedic': 'bone and joint',
    'otolaryngologist': 'ear, nose, and throat doctor',
    'physiatrist': 'rehab doctor',
    'psychiatrist': 'mental health doctor',
    'pulmonologist': 'lung doctor',
    'radiologist': 'imaging doctor',
    'rheumatologist': 'joint and autoimmune doctor',
    'urologist': 'bladder and kidney doctor',

    // ── Anatomy & Body Parts ─────────────────────────────────────────────
    'abdomen': 'belly',
    'abdominal': 'belly',
    'cardiovascular': 'heart and blood vessel',
    'cerebral': 'brain',
    'cervical': 'neck (or cervix)',
    'cranial': 'head/skull',
    'cutaneous': 'skin',
    'gastrointestinal': 'stomach and gut',
    'hepatic': 'liver',
    'lumbar': 'lower back',
    'musculoskeletal': 'muscles and bones',
    'myocardial': 'heart muscle',
    'ocular': 'eye',
    'pulmonary': 'lung',
    'renal': 'kidney',
    'thoracic': 'chest',
    'vascular': 'blood vessel',

    // ── Conditions & Diagnoses ───────────────────────────────────────────
    'anemia': 'low red blood cells',
    'arrhythmia': 'irregular heartbeat',
    'bronchitis': 'airway inflammation',
    'carcinoma': 'cancer',
    'cellulitis': 'skin infection',
    'cerebrovascular': 'brain blood vessel',
    'cholesterol': 'blood fat',
    'cirrhosis': 'liver scarring',
    'comorbidity': 'other health condition',
    'contraindication': 'reason not to use',
    'deficiency': 'lack of',
    'dementia': 'memory loss disease',
    'dermatitis': 'skin rash',
    'diabetes': 'high blood sugar disease',
    'diagnosis': 'finding out what is wrong',
    'dysfunction': 'not working right',
    'edema': 'swelling',
